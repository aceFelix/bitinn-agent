<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itniuma.bitinn.mapper.article.TagMapper">

    <resultMap id="tagResultMap" type="com.itniuma.bitinn.pojo.entity.Tag">
        <id property="id" column="id"/>
        <result property="tagName" column="tag_name"/>
        <result property="tagColor" column="tag_color"/>
    </resultMap>

    <select id="findByArticleId" resultMap="tagResultMap">
        SELECT t.id, t.tag_name, t.tag_color
        FROM tag t
                 INNER JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
    </select>

    <select id="listByUser" resultMap="tagResultMap">
        SELECT id, tag_name, tag_color
        FROM tag
        WHERE create_user = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="list" resultMap="tagResultMap">
        SELECT id, tag_name, tag_color
        FROM tag
        ORDER BY id
    </select>

</mapper>
